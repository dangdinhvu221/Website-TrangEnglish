    {
      "id": "making-plans",
      "levelId": "cap-2",
      "title": "Making plans",
      "summary": "Build invites, picture chase, and write.",
      "body": "Invite a friend and agree or decline plans.",
      "tip": "Offer two time options so your friend can choose easily.",
      "exercises": [
        {
          "id": "plans-sentence",
          "type": "sentence",
          "title": "Build a sentence",
          "prompt": "Build the full dialogue line.",
          "items": [
            {
              "words": [
                "you",
                "Are",
                "free",
                "on",
                "Saturday",
                "?"
              ],
              "answer": "Are you free on Saturday?"
            },
            {
              "words": [
                "about",
                "How",
                "3",
                "pm",
                "at",
                "the",
                "park",
                "?"
              ],
              "answer": "How about 3 pm at the park?"
            },
            {
              "words": [
                "Sorry",
                ",",
                "I",
                "can't",
                ".",
                "I",
                "have",
                "a",
                "test"
              ],
              "answer": "Sorry, I can't. I have a test"
            }
          ]
        },
        {
          "id": "plans-picture",
          "type": "picture",
          "title": "Picture chase",
          "prompt": "Choose the line that fits the situation.",
          "items": [
            {
              "image": "📅",
              "options": [
                "Are you free?",
                "I am hungry.",
                "Good night."
              ],
              "answer": "Are you free?"
            },
            {
              "image": "🏞️",
              "options": [
                "At the park",
                "In the fridge",
                "On the bus"
              ],
              "answer": "At the park"
            },
            {
              "image": "🙌",
              "options": [
                "See you there!",
                "I am sleepy.",
                "Open the door."
              ],
              "answer": "See you there!"
            }
          ]
        },
        {
          "id": "plans-write",
          "type": "write",
          "title": "Write — Invite a friend",
          "prompt": "Write a short invitation.",
          "items": [
