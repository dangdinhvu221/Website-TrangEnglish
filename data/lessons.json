{
  "levels": [
    {
      "id": "cap-1",
      "name": "Level 1",
      "title": "English — Level 1",
      "description": "Fun practice: flashcards, picture chase, and matching — great for younger learners."
    },
    {
      "id": "cap-2",
      "name": "Level 2",
      "title": "English — Level 2",
      "description": "Sentence building, writing, and matching — short conversations for older learners."
