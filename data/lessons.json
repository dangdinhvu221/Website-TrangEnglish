  "lessons": [
    {
      "id": "quick-lesson",
      "levelId": "cap-1",
      "title": "Quick lesson",
      "summary": "Edit this summary.",
      "body": "Short intro for students.",
      "tip": "Teacher tip here.",
      "exercises": [
        {
          "id": "quick-lesson-flip-1",
          "type": "flip",
          "title": "Flashcards",
          "prompt": "Flip the cards.",
          "cards": [
            {
              "front": "A",
              "back": "apple"
            },
            {
              "front": "B",
              "back": "ball"
            }
          ]
        },
        {
          "id": "quick-lesson-picture-2",
          "type": "picture",
          "title": "Picture chase",
          "prompt": "Choose the correct word.",
          "items": [
            {
              "image": "🍎",
              "options": [
                "apple",
                "ball",
                "cat"
              ],
              "answer": "apple"
            },
            {
              "image": "/images/apple.svg",
              "imageAlt": "Apple",
              "options": [
                "apple",
                "dog",
                "sun"
              ],
              "answer": "apple"
            }
          ]
        },
        {
          "id": "quick-lesson-write-3",
          "type": "write",
          "title": "Write",
          "prompt": "Type the answer.",
          "items": [
            {
              "prompt": "Write the word for 1",
              "hint": "o…",
              "answer": "one"
            }
          ]
        }
      ]
    },
    {
      "id": "numbers-1-20",
      "levelId": "cap-1",
      "title": "Numbers 1–20",
      "summary": "Match, write, and flip number cards.",
      "body": "Practise counting and spelling numbers from 1 to 20.",
      "tip": "Count objects on your desk, then do the exercises.",
      "exercises": [
        {
          "id": "numbers-match",
          "type": "match",
          "title": "Match — Numbers",
          "prompt": "Match the word with the number.",
          "pairs": [
            {
              "left": "one",
              "right": "1"
            },
            {
              "left": "two",
              "right": "2"
            },
            {
              "left": "five",
              "right": "5"
            },
            {
              "left": "ten",
              "right": "10"
            },
            {
              "left": "twelve",
              "right": "12"
            },
            {
              "left": "twenty",
              "right": "20"
            }
          ]
        },
        {
          "id": "numbers-write",
          "type": "write",
          "title": "Write — How many?",
          "prompt": "Type the English word for each number.",
          "items": [
            {
              "prompt": "Write the English word for 3",
              "hint": "Starts with th…",
              "answer": "three"
            },
            {
              "prompt": "Write the English word for 7",
              "hint": "Five letters, starts with s…",
              "answer": "seven"
            },
            {
              "prompt": "Write the English word for 11",
              "hint": "eleven = 10 + 1",
              "answer": "eleven"
            },
            {
              "prompt": "Write the English word for 15",
              "hint": "fifteen — related to five",
              "answer": "fifteen"
            }
          ]
        },
        {
          "id": "numbers-flip",
          "type": "flip",
          "title": "Flashcards — Count",
          "prompt": "Flip to see the spelling.",
          "cards": [
            {
              "front": "4",
              "back": "four"
            },
            {
              "front": "6",
              "back": "six"
            },
            {
              "front": "8",
              "back": "eight"
            },
            {
              "front": "9",
              "back": "nine"
            },
            {
              "front": "13",
              "back": "thirteen"
            },
            {
              "front": "16",
              "back": "sixteen"
            }
          ]
        }
      ]
    },
    {
      "id": "colours",
      "levelId": "cap-1",
      "title": "Colours",
      "summary": "Picture chase, match, and sentence building.",
      "body": "Recognise and name colours in English.",
      "tip": "Point to things around the room and say their colour.",
      "exercises": [
        {
          "id": "colours-picture",
          "type": "picture",
          "title": "Picture chase",
          "prompt": "What colour is this?",
          "items": [
            {
              "image": "/images/color-red.svg",
              "imageAlt": "Red circle",
              "options": [
                "red",
                "blue",
                "green"
              ],
              "answer": "red"
            },
            {
              "image": "/images/color-blue.svg",
              "imageAlt": "Blue circle",
              "options": [
                "yellow",
                "blue",
                "pink"
              ],
              "answer": "blue"
            },
            {
              "image": "🟡",
              "options": [
                "green",
                "yellow",
                "brown"
              ],
              "answer": "yellow"
            },
            {
              "image": "🟢",
              "options": [
                "green",
                "orange",
                "white"
              ],
              "answer": "green"
            }
          ]
        },
        {
          "id": "colours-match",
          "type": "match",
          "title": "Match — Colours",
          "prompt": "Match the colour with an example.",
          "pairs": [
            {
              "left": "red",
              "right": "like a strawberry"
            },
            {
              "left": "blue",
              "right": "like the sky"
            },
            {
              "left": "yellow",
              "right": "like the sun"
            },
            {
              "left": "green",
              "right": "like grass"
            },
            {
              "left": "pink",
              "right": "like a flower"
            },
            {
              "left": "black",
              "right": "like night"
            }
          ]
        },
        {
          "id": "colours-sentence",
          "type": "sentence",
          "title": "Build a sentence",
          "prompt": "Catch the words and make a full sentence.",
          "items": [
            {
              "words": [
                "is",
                "It",
                "blue"
              ],
              "answer": "It is blue"
            },
            {
              "words": [
                "colour",
                "is",
                "My",
                "red",
                "favourite"
              ],
              "answer": "My favourite colour is red"
            },
            {
              "words": [
                "What",
                "is",
                "it",
                "colour",
                "?"
              ],
              "answer": "What colour is it?"
            }
          ]
        }
      ]
    },
    {
      "id": "family",
      "levelId": "cap-1",
      "title": "My family",
      "summary": "Flashcards, match, and writing about family.",
      "body": "Introduce people in your family in English.",
      "tip": "Look at a family photo and name each person.",
      "exercises": [
        {
          "id": "family-flip",
          "type": "flip",
          "title": "Flashcards — Family",
          "prompt": "Flip the cards to learn the words.",
          "cards": [
            {
              "front": "👩",
              "back": "mum / mother"
            },
            {
              "front": "👨",
              "back": "dad / father"
            },
            {
              "front": "👧",
              "back": "sister"
            },
            {
              "front": "👦",
              "back": "brother"
            },
            {
              "front": "👵",
              "back": "grandma"
            },
            {
              "front": "👴",
              "back": "grandpa"
            }
          ]
        },
        {
          "id": "family-match",
          "type": "match",
          "title": "Match — Family",
          "prompt": "Match the word with the meaning.",
          "pairs": [
            {
              "left": "mum",
              "right": "mother"
            },
            {
              "left": "dad",
              "right": "father"
            },
            {
              "left": "sister",
              "right": "a girl in your family"
            },
            {
              "left": "brother",
              "right": "a boy in your family"
            }
          ]
        },
        {
          "id": "family-write",
          "type": "write",
          "title": "Write — My family",
          "prompt": "Fill in the missing word.",
          "items": [
            {
              "prompt": "This is my ___ (mother)",
              "hint": "mum or mother",
              "answer": "mum",
              "accept": [
                "mum",
                "mother",
                "mom"
              ]
            },
            {
              "prompt": "This is my ___ (father)",
              "hint": "dad or father",
              "answer": "dad",
              "accept": [
                "dad",
                "father"
              ]
            },
            {
              "prompt": "I have one ___ (girl sibling)",
              "hint": "sister",
              "answer": "sister"
            }
          ]
        }
      ]
    },
